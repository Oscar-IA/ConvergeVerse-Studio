# Base URL of the Python FastAPI API (must be port 8000, not the Next.js port).
# Manga UI: apps/web/app/manga/page.tsx → POST {this}/api/pipeline/manga
NEXT_PUBLIC_API_URL=http://localhost:8000
# Perfil para guardar ajustes del lector en Supabase (tabla user_reader_settings)
# NEXT_PUBLIC_READER_PROFILE_ID=default
