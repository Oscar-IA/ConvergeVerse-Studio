# =============================================================================
# CONVERGEVERSE STUDIO — "Combustible" (API Keys)
# Copy this file to `.env` in the same folder (apps/api/) and fill in real values.
# Never commit `.env` to git.
# =============================================================================

# --- ScriptAgent: pick ONE provider (Anthropic OR OpenAI) ---
# Priority: ANTHROPIC_API_KEY is used first if set; else OPENAI_API_KEY.

# Anthropic (Claude) — keys start with sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# Optional: claude-3-5-sonnet-20241022, claude-sonnet-4-20250514, etc.
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI (GPT) — optional if you use Claude instead
OPENAI_API_KEY=sk-your-openai-key-here
# URL pública de esta API (para enlaces TTS en disco: POST /chapters/voice-local)
# API_PUBLIC_URL=http://localhost:8000
# OPENAI_MODEL=gpt-4o
#
# OpenAI TTS — «La Voz del Multiverso» (narración capítulos → Storage)
# OPENAI_TTS_MODEL=tts-1-hd
# OPENAI_TTS_VOICE=onyx
# Bucket Supabase Storage para MP3 (créalo en Dashboard → Storage)
# SUPABASE_STORAGE_BUCKET_NARRATION=narration

# --- Replicate: ImageAgent (Flux — visual magic) ---
# Required for real panel images. Uses black-forest-labs/flux-schnell.
# Get token: https://replicate.com/account/api-tokens
# Misma clave para paneles manga (ImageAgent) y para ilustración «Legado» al publicar capítulo (Story Engine).
REPLICATE_API_TOKEN=r8_your-replicate-token-here
# Optional: seconds per panel (default 180). Two panels = up to 2× this, sequentially.
# REPLICATE_TIMEOUT_SEC=180

# If Replicate fails or has no token: Pollinations (optional) → placeholders de diseño.
# POLLINATIONS_FALLBACK=true
# POLLINATIONS_WIDTH=768
# POLLINATIONS_HEIGHT=1024
#
# Tras fallo de Replicate: "pollinations" (default) o "design" = solo placeholders (carga rápida, layout fijo).
# REPLICATE_FAIL_FALLBACK=pollinations
#
# --- Crónicas / portada «Laguna Legacy» (chronicle_archive → Replicate) ---
# Prompt maestro: nobleza Aethel-Arévalo + BOND OS (ver docs/CONVERGEVERSE_LAGUNA_LEGACY_MASTER_PROMPT.md).
# CONVERGEVERSE_COVER_USE_FULL_MASTER=true   # false = solo variante compacta
# CHRONICLE_REPLICATE_PROMPT_MAX=1800         # tope de caracteres enviados a flux-schnell
#
# URL pública del front (Next) para servir /public/manga-placeholders/panel-0.svg y panel-1.svg.
# En local: http://localhost:3000 — así el lector manga muestra marcos “Konosuba preview” sin depender de APIs.
# WEB_APP_PUBLIC_URL=http://localhost:3000

# --- Story Engine: arquitectura de temporada (cour) ---
# Longitud del cour en episodios (default 12). Opcional: generation_config.courLength en POST /generate
# CONVERGE_COUR_LENGTH=12

# --- Supabase (Postgres): capítulos / edits / memoria (story_engine) ---
# Project URL y clave: Supabase → Settings → API
# Para el backend FastAPI usa preferentemente service_role (secreta), no la anon pública.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-or-anon-key
#
# Creative Hub (referencias + ideation_vault): ejecuta docs/supabase_creative_hub.sql en el mismo proyecto.

# --- World Engine (SQLite): Season > Chapter > novel | manga | anime ---
# Default path: apps/api/data/convergeverse.db
# CONVERGE_DB_PATH=

# --- Pipeline maestro (manga): JSON por capítulo ---
# Por defecto: apps/api/storage/season_1/chapter_{n}.json
# CONVERGE_STORAGE_ROOT=
